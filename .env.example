# LLM Provider Configuration
# Required: Your OpenAI API key
OPENAI_API_KEY=your_key_here

# Optional: LLM model name (default: gpt-4o-mini)
# Examples: gpt-3.5-turbo, gpt-4-turbo, gpt-4o
OPENAI_MODEL=gpt-4o-mini

# Optional: Custom OpenAI-compatible endpoint
# Use this for proxies, local deployments (e.g., Ollama, LM Studio), or custom APIs
# Examples:
# - Ollama: http://localhost:11434/v1
# - Local: https://api.local-llm.com
# - Proxy: https://openai-proxy.example.com
OPENAI_BASE_URL=

# Search Configuration
# Optional: Custom DuckDuckGo HTML endpoint (default: https://html.duckduckgo.com/html/)
# Use this for testing, debugging, or if you have a custom search service
DUCKDUCKGO_BASE_URL=https://html.duckduckgo.com/html/

# Search Parameters
MAX_SEARCH_RESULTS=10
SUMMARIZE_TOP_N=3

# Performance & Timeout Settings
REQUEST_TIMEOUT=15.0
MAX_RETRIES=3
RATE_LIMIT_DELAY=0.5

# Logging (optional)
# LOG_LEVEL=INFO
# LOG_FILE=app.log
